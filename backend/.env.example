# Configuración de Base de Datos
DB_NAME=hotel.db

# API Keys (Google Gemini)
GOOGLE_API_KEY=tu_api_key_aqui

# Clave Secreta para JWT
JWT_SECRET_KEY=tu_clave_secreta_aqui

# ==========================================
# CORS — Orígenes permitidos (separados por coma)
# Agregar IPs de Tailscale para acceso remoto: http://100.x.x.x:3000
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:3000,http://127.0.0.1:8501

# ==========================================
# Monitoreo — Healthchecks.io (push-based uptime)
# Crear cuenta gratis en https://healthchecks.io
# Crear un check y copiar la URL de ping
# ==========================================
HEALTHCHECK_PING_URL=

# ==========================================
# Alertas — Discord Webhook
# Crear webhook en Discord: Server Settings → Integrations → Webhooks
# Los errores del sistema se enviarán a este canal
# ==========================================
DISCORD_WEBHOOK_URL=

# ==========================================
# CORS — Orígenes permitidos (separados por coma)
# Por defecto cubre localhost. Agregar IPs de staging/producción.
# Ejemplo staging: http://34.151.217.242:3000,http://34.151.217.242:8501
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:3000,http://127.0.0.1:8501