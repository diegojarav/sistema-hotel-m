{
  "name": "hotel-munich-workspace",
  "private": true,
  "description": "Hotel PMS - Hospedaje Los Monges workspace task runner",
  "scripts": {
    "reset-db": "python scripts/reset_local_db.py",
    "test:backend": "cd backend && python -m pytest tests/ -v",
    "test:frontend": "cd frontend_mobile && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --port 8000",
    "dev:mobile": "cd frontend_mobile && npm run dev",
    "dev:pc": "cd frontend_pc && streamlit run app.py",
    "deploy:staging": "bash scripts/deploy_staging.sh",
    "lint:frontend": "cd frontend_mobile && npx next lint"
  }
}
