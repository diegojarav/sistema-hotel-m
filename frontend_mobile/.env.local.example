# Hotel Munich Frontend Mobile - Environment Configuration
# =========================================================
# Copy this file to .env.local and update the API URL
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# LAN access (replace with your machine's IP):
# NEXT_PUBLIC_API_URL=http://192.168.3.140:8000
#
# Staging (GCP VM):
# NEXT_PUBLIC_API_URL=http://34.151.217.242:8000
