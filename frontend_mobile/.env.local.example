# Hotel Munich Frontend Mobile - Environment Configuration
# =========================================================
# Copy this file to .env.local and update the API URL
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# LAN access (replace with your machine's IP):
# NEXT_PUBLIC_API_URL=http://192.168.x.x:8000
#
# Staging/Production (GCP VM — IP changes on restart):
# NEXT_PUBLIC_API_URL=http://VM_IP:8000
